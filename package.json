{
  "name": "hace-reportes",
  "version": "1.0.0",
  "description": "Genera informes de actividades desde un archivo Markdown estructurado y produce: - HTML listo para revisar. - PDF tamaño carta automático (opcional) usando LibreOffice.",
  "main": "index.js",
  "scripts": {
    "dev:webapp": "concurrently -k \"node server/index.js\" \"astro dev --host --port 4323\"",
