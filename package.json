    "start": "NODE_ENV=production node server/index.js",
    "astro": "astro",
    "generar": "node generar-reporte.js",
    "listar": "node listar-reportes.js",
    "ver": "node ver-reporte.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
