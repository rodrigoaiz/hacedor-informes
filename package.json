  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "basic-auth": "^2.0.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.3",
    "multer": "^2.1.1",
    "puppeteer": "^24.37.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
